{
  "scriptDelta" : 15,
  "tabs": [
    {
      "id": "active",
      "pretty": "Active Effects",
      "description": "This menu shows all the currently active effects.\n\nClick on a effect to check its buffs and debuffs.",
      "paneTitle": "Active Effects"
    },
    {
      "id": "codex",
      "pretty": "Effect Codex",
      "description": "This menu all the effects you discovered so far!\n\nClick on a effect to check its buffs and debuffs, as well as its tiers.",
      "paneTitle": "Discovered effects"
    }
  ],
  "effects": {
    "gracePeriod": {
      "levels": 1,
      "pretty": "Beginner's Grace",
      "type": "special",
      "description": "^#00ebce;Weight^reset; and ^#b8eb00;experience^reset; aren't lost on death, changes to traits cost no ^#b8eb00;experience^reset; and can be done without an \n^orange;Infusion Table^reset;.",
      "note": "Obtained by starting a new character.",
      "ephemeral": true,
      "stats": [
        ["deathPenalty", "sub", 1, 0],
        ["traitExperienceCost", "mult", 0, 0]
      ],

      "duration": 1800
    },
    "shipWorld": {
      "levels": 1,
      "pretty": "Artificial Gravity",
      "type": "positive",
      "description": "^cyan;S.A.I.L.^reset; is adjusting the artifical gravity on this ship to accommodate your weight, ^#1a87ed;increasing mobility^reset; and slowing ^#00ebce;weight loss^reset;.",
      "note": "Obtained while on player ships.",
      "stats": [
        ["metabolism", "mult", 0.25, 0],
        ["jumpPenalty", "mult", 0.5, 0]
      ],

      "script": "/scripts/starpounds/effects/shipWorld.lua",
      "duration": 60
    },
    "feedingTube": {
      "levels": 5,
      "pretty": "Diluted Acid",
      "type": "negative",
      "description": "Drinking excessive amounts of liquid has diluted the acid in your stomach, reducing your ^#b8eb00;digestion speed^reset;.",
      "note": "Obtained by using a feeding tube.",
      "stats": [
        ["digestion", "mult", 0.85, -0.15],
        ["bloatDigestion", "mult", 0.85, -0.15],
        ["voreDamage", "mult", 0.85, -0.15]
      ],

      "duration": 3,
      "expirePerLevel": true,
      "expireOnDeath": true
    },
    "satiated": {
      "levels": 1,
      "pretty": "Satiated",
      "type": "positive",
      "description": "Eating adequately has satiated your body, slowing ^#00ebce;weight loss^reset; and ^#d5ab36;hunger^reset;.",
      "note": "Obtained by filling up your hunger meter.",
      "stats": [
        ["metabolism", "mult", 0.5, 0],
        ["hunger", "mult", 0.25, 0]
      ],

      "proxyEffect": "starpoundseffectproxy_satiated",

      "duration": 60,
      "expireOnDeath": true
    },
    "stomachStretch": {
      "levels": 5,
      "pretty": "Stretched Stomach",
      "description": "Over stuffing your stomach has caused it to stretch, granting ^#f96aa6;bonus capacity^reset; at the cost of ^#f96aa6;increased strain^reset;.",
      "note": "Obtained by filling up your stomach an excessive amount.",
      "stats": [
        ["capacity", "mult", 1.1, 0.1],
        ["stuffingDamage", "mult", 1.1, 0.1],
        ["strainedPenalty", "add", 0.1, 0.1]
      ],

      "proxyEffect": "starpoundseffectproxy_stomachstretch",

      "duration": 300,
      "expirePerLevel": true,
      "expireOnDeath": true
    },
    "caloriumExtractor": {
      "levels": 10,
      "pretty": "Calorically Drained",
      "type": "negative",
      "particle": true,
      "description": "Rapidly removing fat has drained you of nutrients, ^#d5ab36;reducing food restored^reset;, ^#d5ab36;increasing hunger^reset;, and ^#1a87ed;decreasing mobility^reset;.",
      "note": "Obtained by extracting fat with the Calorium Extractor.",
      "stats": [
        ["foodValue", "mult", 0.975, -0.025],
        ["hunger", "add", 0.025, 0.025],
        ["movement", "sub", 0.02, 0.02]
      ],

      "duration": 1800
    },
    "treadmill": {
      "levels": 3,
      "pretty": "Corpulent Cardio",
      "type": "positive",
      "particle": true,
      "description": "Exercising has improved your endurance, granting you ^#1a87ed;extra mobility^reset;.",
      "note": "Obtained by losing weight on the treadmill.",
      "stats": [
        ["movement", "add", 0.05, 0.025],
        ["jumpPenalty", "sub", 0.025, 0.0125],
        ["swimPenalty", "sub", 0.025, 0.0125]
      ],

      "duration": 600,
      "expirePerLevel": true,
      "expireOnDeath": true
    },
    "groundSlam": {
      "levels": 5,
      "pretty": "Tender Posterior",
      "type": "negative",
      "description": "Slamming your rear into the ground has made it sore, slightly increasing your ^#ccbbff;ground slam cooldown^reset;.",
      "note": "Obtained by using the Ground Slam tech.",
      "stats": [
        ["groundSlamCooldown", "mult", 1.05, 0.05]
      ],

      "proxyEffect": "starpoundseffectproxy_groundslam",

      "duration": 10,
      "expireOnDeath": true
    },
    "bloatCola": {
      "levels": 9,
      "pretty": "Bloat Cola",
      "description": "With our patented** ^#5d50e5;hyper-carbonic fizz^reset;, Bloat Cola is scientifically proven to test the limits of your sweatpants.",
      "note": "Obtained by drinking Bloat Cola.",
      "stats": [
        ["gurgleRate", "add", 1, 0.25],
        ["belchChance", "mult", 2, 0],
        ["belchAmount", "mult", 0.25, 0]
      ],

      "effectConfig": {
        "airAmount": 2
      },

      "proxyEffect": "starpoundseffectproxy_bloatcola",

      "script": "/scripts/starpounds/effects/bloatCola.lua",
      "duration": 60,
      "expireOnDeath": true
    },
    "voreSouls": {
      "levels": 100,
      "pretty": "Soul Siphon",
      "type": "positive",
      "description": "The ^#81f8fe;souls^reset; of digested prey are bound to your figure, granting ^#cf1b1b;bonus health^reset;, and increasing your predator abilities.",
      "note": "Obtained by digesting prey with the Soul Siphon skill.",
      "stats": [
        ["health", "add", 0.01, 0.01],
        ["voreEscapeChance", "mult", 0.9925, -0.0075],
        ["voreEnergy", "sub", 0.0075, 0.0075]
      ],

      "effectConfig": {
        "healPercentage": 0.25 // Percent max health of prey to heal by.
      },

      "script": "/scripts/starpounds/effects/voreSouls.lua",
      "duration": 5,
      "expirePerLevel": true
    },
    "alipos": {
      "levels": 1,
      "pretty": "Blessing of Afthonia",
      "type": "special",
      "description": "You have been endowed Afthonia's blessing from her priestess, Alipos, ^#d5ab36;increasing food restored^reset; and ^#b8eb00;experience gained^reset;.",
      "note": "Obtained by speaking with Alipos.",
      "ephemeral": true,
      "stats": [
        ["foodValue", "add", 0.25, 0],
        ["experienceMultiplier", "add", 0.1, 0]
      ],

      "duration": 1800,
      "expireOnDeath": true
    },
    // Traits.
    "passiveMilk": {
      "levels": 1,
      "pretty": "^#ffe5d9;Passive Milk Production",
