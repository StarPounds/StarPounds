      "belch": {
        "type": "ember",
        "size": 1.25,
        "color": [60, 150, 224, 200],
        "position": [0, 0],
        "destructionAction": "shrink",
        "destructionTime": 0.2,
        "layer": "middle",
        "timeToLive": 0.5,
        "variance": {"initialVelocity": [5, 3], "size": 0.25, "timeToLive": 0.25}
      },
      "vore": {
        "type": "ember",
        "size": 1,
        "color": [255, 255, 255], // This gets changed in the script
        "position": [0, 0],
        "destructionAction": "fade",
        "destructionTime": 0.25,
        "layer": "middle",
        "variance": {"initialVelocity": [2, 2], "size": 0.5, "timeToLive": 0.05}
      },
      "effect": {
        "type": "ember",
        "size": 1,
        "color": [255, 157, 210, 128],
        "light": [82, 20, 53],
        "position": [0, 0],
        "initialVelocity": [0, 1],
        "finalVelocity": [0, 10],
        "approach": [0, 10],
        "destructionAction": "shrink",
        "destructionTime": 0.2,
        "fade": 1,
        "layer": "back",
        "fullbright": true,
        "timeToLive": 0.1,
        "variance": {
          "position": [1, 2],
          "initialVelocity": [2, 1],
          "size": 0.5,
